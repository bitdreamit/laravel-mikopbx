{
    "name": "bitdreamit/laravel-mikopbx",
    "description": "The most complete Laravel package for MikoPBX — CRM-ready call center with auto dialer, campaigns, live agent panel, web softphone, IVR builder, analytics, recordings, blacklist, callbacks & more.",
    "version": "1.0.1",
    "type": "library",
    "keywords": ["laravel", "mikopbx", "asterisk", "pbx", "voip", "call-center", "crm", "auto-dialer", "ami", "ari"],
    "homepage": "https://github.com/bitdreamit/laravel-mikopbx",
    "license": "MIT",
    "authors": [
        {
            "name": "BitDream IT",
            "email": "info@bitdreamit.com",
            "homepage": "https://bitdreamit.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "BitDreamIT\\MikoPBX\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BitDreamIT\\MikoPBX\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["BitDreamIT\\MikoPBX\\MikoPBXServiceProvider"],
            "aliases": {"MikoPBX": "BitDreamIT\\MikoPBX\\Facades\\MikoPBX"}
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
